{
  "name": "shopify-klaviyo-retention-ops",
  "version": "0.1.0",
  "description": "Shopify and Klaviyo retention operations surface for margin leaks, cohort decay, lifecycle gaps, and offer sequencing.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/shopify-klaviyo-retention-ops.git"
  },
  "keywords": ["shopify", "klaviyo", "ruby", "typescript", "sql", "ecommerce", "retention", "kinetic-gain"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx scripts/run_demo.ts",
    "ruby:test": "ruby ruby/test_retention_score.rb",
    "sql:check": "tsx scripts/check_sql.ts",
    "prerender": "tsx scripts/prerender.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run lint && npm run typecheck && npm run coverage && npm run build && npm run demo && npm run ruby:test && npm run sql:check && npm run prerender && npm run smoke",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1"
  },
  "dependencies": { "express": "^5.2.1" },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.17.0",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.8"
  },
  "engines": { "node": ">=20" }
}
